---
const { title, description = "", activeNav = "" } = Astro.props;

const navItems = [
  { href: "/", label: "Beranda", key: "beranda" },
  { href: "/profil", label: "Profil & Sejarah", key: "profil" },
  { href: "/umkm", label: "Potensi & UMKM", key: "umkm" },
  { href: "/aktivitas", label: "Aktivitas", key: "aktivitas" },
  { href: "/peta", label: "Peta", key: "peta" },
  { href: "/galeri", label: "Galeri", key: "galeri" },
  { href: "/kontak", label: "Kontak", key: "kontak" },
];
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{title} — Dusun Macanan, Magelang</title>
  <meta name="description" content={description} />

  <link href="/assets/img/favicon.png" rel="icon" />
  <link href="/assets/img/apple-touch-icon.png" rel="apple-touch-icon" />

  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />

  <!-- Vendor CSS (bawaan BizLand) -->
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
  <link href="/assets/vendor/aos/aos.css" rel="stylesheet" />
  <link href="/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet" />
  <link href="/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet" />

  <!-- Main CSS (bawaan BizLand) + override warna dusun -->
  <link href="/assets/css/main.css" rel="stylesheet" />
  <link href="/assets/css/custom.css" rel="stylesheet" />

  <slot name="head" />

  <!-- =======================================================
  * Berbasis Template: BizLand oleh BootstrapMade.com
  * https://bootstrapmade.com/bizland-bootstrap-business-template/
  * Lisensi: https://bootstrapmade.com/license/
  ======================================================== -->
</head>
<body class="index-page">

  <header id="header" class="header sticky-top">
    <div class="branding d-flex align-items-center">
      <div class="container position-relative d-flex align-items-center justify-content-between">
        <a href="/" class="logo d-flex align-items-center">
          <h1 class="sitename">Dusun Macanan</h1>
        </a>

        <nav id="navmenu" class="navmenu">
          <ul>
            {navItems.map(item => (
              <li><a href={item.href} class={activeNav === item.key ? "active" : ""}>{item.label}</a></li>
            ))}
          </ul>
          <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>
      </div>
    </div>
  </header>

  <main class="main">
    <slot />
  </main>

  <footer id="footer" class="footer">
    <div class="container footer-top">
      <div class="row gy-4">
        <div class="col-lg-4 col-md-6 footer-about">
          <a href="/" class="d-flex align-items-center">
            <span class="sitename">Dusun Macanan</span>
          </a>
          <div class="footer-contact pt-3">
            <p>Dusun Macanan, Desa Bligo</p>
            <p>Kecamatan Ngluwar, Kabupaten Magelang, Jawa Tengah</p>
            <p class="mt-3"><strong>Email:</strong> <span>ikatanmudamudimacanan2026@gmail.com</span></p>
          </div>
        </div>

        <div class="col-lg-2 col-md-3 footer-links">
          <h4>Tautan</h4>
          <ul>
            {navItems.slice(0, 5).map(item => (
              <li><i class="bi bi-chevron-right"></i> <a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="col-lg-3 col-md-3 footer-links">
          <h4>Lainnya</h4>
          <ul>
            <li><i class="bi bi-chevron-right"></i> <a href="/galeri">Galeri</a></li>
            <li><i class="bi bi-chevron-right"></i> <a href="/kontak">Kontak</a></li>
            <li><i class="bi bi-chevron-right"></i> <a href="/admin/login">Login Admin</a></li>
          </ul>
        </div>

        <div class="col-lg-3 col-md-12">
          <h4>Ikuti Kami</h4>
          <p>Update kegiatan dan informasi terbaru Dusun Macanan.</p>
          <div class="social-links d-flex">
            <a href="https://www.instagram.com/dusunmacanan.official?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="><i class="bi bi-instagram"></i></a>
            <a href="https://www.tiktok.com/@dusun.macanan?is_from_webapp=1&sender_device=pc"><i class="bi bi-tiktok"></i></a>
          </div>
        </div>
      </div>
    </div>

    <div class="container copyright text-center mt-4">
      <p>&copy; {new Date().getFullYear()} <strong class="px-1 sitename">Dusun Macanan</strong>, Bligo, Magelang</p>
    </div>
  </footer>

  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

  <div id="preloader"></div>

  <!-- Vendor JS (bawaan BizLand) -->
  <script is:inline src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script is:inline src="/assets/vendor/php-email-form/validate.js"></script>
  <script is:inline src="/assets/vendor/aos/aos.js"></script>
  <script is:inline src="/assets/vendor/glightbox/js/glightbox.min.js"></script>
  <script is:inline src="/assets/vendor/waypoints/noframework.waypoints.js"></script>
  <script is:inline src="/assets/vendor/purecounter/purecounter_vanilla.js"></script>
  <script is:inline src="/assets/vendor/swiper/swiper-bundle.min.js"></script>
  <script is:inline src="/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
  <script is:inline src="/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>
  <script is:inline src="/assets/js/main.js"></script>

  <!-- Supabase + helper bersama -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script is:inline src="/assets/js/config.js"></script>
  <script is:inline src="/assets/js/dusun.js"></script>

  <slot name="scripts" />
</body>
</html>
