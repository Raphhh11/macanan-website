---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Aktivitas Warga" description="Kumpulan berita dan aktivitas warga Dusun Macanan, Magelang." activeNav="aktivitas">

  <section id="portfolio" class="portfolio section">
    <div class="container section-title" data-aos="fade-up">
      <h2>Aktivitas Warga</h2>
      <p><span>Cerita &amp; Dokumentasi</span> <span class="description-title">Kegiatan Dusun</span></p>
    </div>

    <div class="container">
      <div class="isotope-layout" data-default-filter="*" data-layout="masonry" data-sort="original-order">
        <ul id="filter-list" class="portfolio-filters isotope-filters" data-aos="fade-up" data-aos-delay="100">
          <li data-filter="*" class="filter-active">Semua</li>
        </ul>

        <div id="aktivitas-container" class="row gy-4 isotope-container" data-aos="fade-up" data-aos-delay="200"></div>
      </div>
    </div>
  </section><!-- /Portfolio Section -->

  <script is:inline slot="scripts">
    function slugifyKategori(k) {
      return "filter-" + k.toLowerCase().replace(/[^a-z0-9]+/g, "-");
    }

    (async () => {
      const filterListEl = document.getElementById("filter-list");
      const container = document.getElementById("aktivitas-container");
      showLoading(container, "Memuat daftar aktivitas...");

      const { data, error } = await supabaseClient
        .from("aktivitas").select("*").eq("status", "aktif")
        .order("tanggal", { ascending: false });

      if (error) return showError(container);
      if (!data || data.length === 0) {
        showEmpty(container, "Belum ada aktivitas yang dipublikasikan. Tambahkan lewat admin panel.");
        return;
      }

      // Bangun daftar filter kategori dari data yang benar-benar ada
      const categories = [...new Set(data.map(d => d.kategori))];
      filterListEl.innerHTML = `<li data-filter="*" class="filter-active">Semua</li>` +
        categories.map(k => `<li data-filter=".${slugifyKategori(k)}">${escapeHtml(k)}</li>`).join("");

      container.innerHTML = data.map(item => {
        const foto = splitFotoUrls(item.foto_urls)[0] || "https://placehold.co/600x400/6b8f47/ffffff?text=Aktivitas";
        return `
        <div class="col-lg-4 col-md-6 portfolio-item isotope-item ${slugifyKategori(item.kategori)}">
          <a href="/artikel?slug=${encodeURIComponent(item.slug)}" class="text-decoration-none">
            <img src="${foto}" class="img-fluid" alt="${escapeHtml(item.judul)}">
            <div class="portfolio-info">
              <h4>${escapeHtml(item.judul)}</h4>
              <p>${formatTanggal(item.tanggal)} &middot; ${escapeHtml(item.kategori)}</p>
            </div>
          </a>
        </div>`;
      }).join("");

      // main.js sudah otomatis menginisialisasi Isotope saat window "load".
      // Karena data ini datang belakangan (async), trigger ulang inisialisasi manual:
      if (window.Isotope) {
        const grid = document.querySelector(".isotope-layout .isotope-container");
        const iso = new Isotope(grid, { itemSelector: ".isotope-item", layoutMode: "masonry" });
        filterListEl.querySelectorAll("li").forEach(li => {
          li.addEventListener("click", function () {
            filterListEl.querySelector(".filter-active").classList.remove("filter-active");
            this.classList.add("filter-active");
            iso.arrange({ filter: this.getAttribute("data-filter") });
          });
        });
      }
    })();
  </script>
</BaseLayout>
