---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Aktivitas" description="Detail aktivitas warga Dusun Macanan, Magelang." activeNav="aktivitas">

  <section id="artikel" class="about section">
    <div class="container">
      <a href="/aktivitas" class="btn-get-started mb-4 d-inline-block">&larr; Kembali ke daftar aktivitas</a>
      <div id="artikel-content" class="mt-4"></div>
    </div>
  </section>

  <script is:inline slot="scripts">
    (async () => {
      const container = document.getElementById("artikel-content");
      const slug = getQueryParam("slug");
      if (!slug) {
        showError(container, "Artikel tidak ditemukan. Kembali ke daftar aktivitas.");
        return;
      }
      showLoading(container, "Memuat artikel...");

      const { data, error } = await supabaseClient
        .from("aktivitas").select("*").eq("slug", slug).eq("status", "aktif").single();

      if (error || !data) {
        showError(container, "Artikel tidak ditemukan atau belum dipublikasikan.");
        return;
      }

      document.title = `${data.judul} — Dusun Macanan, Magelang`;

      const fotos = splitFotoUrls(data.foto_urls);
      const galeriHtml = fotos.map(f => `<img src="${f}" class="img-fluid rounded mb-3" alt="${escapeHtml(data.judul)}" loading="lazy" />`).join("");
      const isiHtml = (data.isi || "").split("\n").filter(Boolean).map(p => `<p>${escapeHtml(p)}</p>`).join("");

      container.innerHTML = `
        <p class="badge-kategori">${escapeHtml(data.kategori)}</p>
        <p class="text-muted">${formatTanggal(data.tanggal)}</p>
        <h1>${escapeHtml(data.judul)}</h1>
        <div class="row mt-4">
          <div class="col-lg-8">${galeriHtml}<div class="mt-3">${isiHtml}</div></div>
        </div>
      `;
    })();
  </script>
</BaseLayout>
