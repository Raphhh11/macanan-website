---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Beranda" description="Website resmi Dusun Macanan, Bligo, Ngluwar, Magelang." activeNav="beranda">

  <!-- Hero Section -->
  <section id="hero" class="hero section light-background">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-7 d-flex flex-column justify-content-center" data-aos="zoom-out">
          <h1 id="hero-title">Selamat Datang di <span>Dusun Macanan</span></h1>
          <p id="hero-tagline">Memuat...</p>
          <div class="d-flex">
            <a href="/profil" class="btn-get-started">Jelajahi Profil</a>
            <a href="/peta" class="btn-watch-video d-flex align-items-center"><i class="bi bi-map"></i><span>Lihat Peta</span></a>
          </div>
        </div>
      </div>
    </div>
  </section><!-- /Hero Section -->

  <!-- Featured / Quick Links Section -->
  <section id="featured-services" class="featured-services section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="100">
          <div class="service-item position-relative">
            <div class="icon"><i class="bi bi-shop icon"></i></div>
            <h4><a href="/umkm" class="stretched-link">Potensi & UMKM</a></h4>
            <p>Produk dan usaha unggulan warga Dusun Macanan.</p>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="200">
          <div class="service-item position-relative">
            <div class="icon"><i class="bi bi-calendar-event icon"></i></div>
            <h4><a href="/aktivitas" class="stretched-link">Aktivitas Warga</a></h4>
            <p>Dokumentasi kegiatan dan berita terbaru dusun.</p>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="300">
          <div class="service-item position-relative">
            <div class="icon"><i class="bi bi-map icon"></i></div>
            <h4><a href="/peta" class="stretched-link">Peta Interaktif</a></h4>
            <p>Lokasi fasilitas, batas wilayah, dan rute di dusun.</p>
          </div>
        </div>
        <div class="col-xl-3 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="400">
          <div class="service-item position-relative">
            <div class="icon"><i class="bi bi-images icon"></i></div>
            <h4><a href="/galeri" class="stretched-link">Galeri Foto</a></h4>
            <p>Dokumentasi fasilitas umum dan kegiatan warga.</p>
          </div>
        </div>
      </div>
    </div>
  </section><!-- /Featured Section -->

  <!-- Stats Section (Data Demografis) -->
  <section id="stats" class="stats section">
    <div class="container section-title" data-aos="fade-up">
      <h2>Sekilas Data Dusun</h2>
    </div>
    <div class="container" data-aos="fade-up" data-aos-delay="100">
      <div id="stats-grid" class="row gy-4"></div>
    </div>
  </section><!-- /Stats Section -->

  <!-- Aktivitas Terbaru -->
  <section id="portfolio" class="portfolio section">
    <div class="container section-title" data-aos="fade-up">
      <h2>Aktivitas Terbaru</h2>
      <p><span>Kegiatan</span> <span class="description-title">Dusun Macanan</span></p>
    </div>
    <div class="container">
      <div id="aktivitas-terbaru" class="row gy-4"></div>
      <div class="text-center mt-4" data-aos="fade-up">
        <a href="/aktivitas" class="btn-get-started">Lihat Semua Aktivitas</a>
      </div>
    </div>
  </section><!-- /Portfolio Section -->

  <script is:inline slot="scripts">
    (async () => {
      const { data, error } = await supabaseClient.from("profil").select("*").eq("id", 1).single();
      if (!error && data) {
        document.getElementById("hero-title").innerHTML = `Selamat Datang di <span>${escapeHtml(data.nama_dusun || "Dusun Macanan")}</span>`;
        document.getElementById("hero-tagline").textContent = data.tagline || "";
      }
    })();

    (async () => {
      const container = document.getElementById("stats-grid");
      showLoading(container, "Memuat data demografi...");
      const { data, error } = await supabaseClient.from("demografi").select("*").order("urutan");
      if (error) return showError(container);
      if (!data || data.length === 0) return showEmpty(container, "Data demografis belum diisi.");
      container.innerHTML = data.map(item => `
        <div class="col-lg-3 col-md-6 d-flex flex-column align-items-center">
          <i class="bi bi-bar-chart-line"></i>
          <div class="stats-item">
            <span>${escapeHtml(item.nilai)}</span>
            <p>${escapeHtml(item.label)}${item.keterangan ? " (" + escapeHtml(item.keterangan) + ")" : ""}</p>
          </div>
        </div>`).join("");
    })();

    (async () => {
      const container = document.getElementById("aktivitas-terbaru");
      showLoading(container, "Memuat aktivitas...");
      const { data, error } = await supabaseClient
        .from("aktivitas").select("*").eq("status", "aktif")
        .order("tanggal", { ascending: false }).limit(3);
      if (error) return showError(container);
      if (!data || data.length === 0) return showEmpty(container, "Belum ada aktivitas yang dipublikasikan.");
      container.innerHTML = data.map(item => {
        const foto = splitFotoUrls(item.foto_urls)[0] || "https://placehold.co/600x400/2f8f5b/ffffff?text=Aktivitas";
        return `
        <div class="col-lg-4 col-md-6">
          <a href="/artikel?slug=${encodeURIComponent(item.slug)}" class="text-decoration-none">
            <div class="portfolio-item isotope-item">
              <img src="${foto}" class="img-fluid" alt="${escapeHtml(item.judul)}">
              <div class="portfolio-info">
                <h4>${escapeHtml(item.judul)}</h4>
                <p>${formatTanggal(item.tanggal)}</p>
              </div>
            </div>
          </a>
        </div>`;
      }).join("");
    })();
  </script>
</BaseLayout>
